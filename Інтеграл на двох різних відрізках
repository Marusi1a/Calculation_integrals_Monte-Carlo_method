def monte_carlo_1d(f, a, b, n):
    x = np.random.uniform(a, b, n)
    y = f(x)
    integral = (b - a) * np.mean(y)
    return integral
# Функція під інтегралом [0,1] U [3,5]
def f4(x):
    return x**2
"""
 Monte Carlo інтегрування на множині:
    [0,1] U [3,5]    """
def monte_carlo_union(n):
    # Довжина першого відрізка
    length1 = 1
    # Довжина другого відрізка
    length2 = 2

    # Загальна довжина області
    total = length1 + length2
    values = []

    for _ in range(n):

        # випадковий вибір відрізка
        r = np.random.uniform(0, total)

        if r <= length1:
            x = np.random.uniform(0, 1)
        else:
            x = np.random.uniform(3, 5)

        # Обчислення значення функції
        values.append(f4(x))

    # Формула Монте-Карло
    return total * np.mean(values)

