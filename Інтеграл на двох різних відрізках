"""
    Обчислення інтеграла методом Монте-Карло
    на множині [0,1] ∪ [3,5]
    з візуалізацією
    """

def monte_carlo_union_visual(n):
    # Довжина першого проміжку [0,1]
    length1 = 1

    # Довжина другого проміжку [3,5]
    length2 = 2

    # Загальна довжина області інтегрування
    total_length = length1 + length2

    # Сюди будемо зберігати значення функції
    values = []

    # Координати точок для побудови графіка
    x_points = []
    y_points = []

    # Максимальне значення функції на [3,5]
    ymax = f4(5)

    # Генеруємо n випадкових точок
    for _ in range(n):

        # Випадковий вибір одного з двох відрізків
        r = np.random.uniform(0, total_length)

        if r <= length1:
            x = np.random.uniform(0, 1)
        else:
            x = np.random.uniform(3, 5)

        # Випадкове y для візуалізації
        y = np.random.uniform(0, ymax)

        # Зберігаємо x для формули Монте-Карло
        values.append(f4(x))

        # Зберігаємо точки для графіка
        x_points.append(x)
        y_points.append(y)

    # Формула Монте-Карло
    integral = total_length * np.mean(values)

    print(f"Кількість точок n = {n}")
    print(f"Наближене значення інтеграла = {integral:.6f}")

    # ВІЗУАЛІЗАЦІЯ
    x_points = np.array(x_points)
    y_points = np.array(y_points)

    # Точки, що лежать під графіком
    inside = y_points <= f4(x_points)

    plt.figure(figsize=(10, 6))

    # Графік на [0,1]
    x1 = np.linspace(0, 1, 300)
    plt.plot(x1, f4(x1), linewidth=2)

    # Графік на [3,5]
    x2 = np.linspace(3, 5, 300)
    plt.plot(x2, f4(x2), linewidth=2)

    # Зелені точки — під графіком
    plt.scatter(x_points[inside],
        y_points[inside],
        color='green',
        s=8,
        label='Точки під графіком')

    # Червоні — над графіком
    plt.scatter(x_points[~inside],
        y_points[~inside],
        color='red',
        s=8,
        label='Точки поза графіком')

    plt.xlabel('x')
    plt.ylabel('y')
    plt.title('Візуалізація методу Монте-Карло\nдля множини [0,1] ∪ [3,5]')

    plt.grid(True)
    plt.legend()
    plt.show()

    return integral


